# ----------------------------------------------------------------------------
# Maven Wrapper startup script
# ----------------------------------------------------------------------------

set -euf

MVNW_REPOURL="${MVNW_REPOURL:-}"
BASE_DIR="$(cd "$(dirname "$0")" && pwd -P)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPS_FILE="$WRAPPER_DIR/maven-wrapper.properties"
JAR_FILE="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$PROPS_FILE" ]; then
  echo "Missing $PROPS_FILE" >&2
  exit 1
fi

get_prop() {
  key="$1"
  # shellcheck disable=SC2002
  cat "$PROPS_FILE" | grep "^${key}=" | cut -d'=' -f2-
}

WRAPPER_URL="$(get_prop wrapperUrl || true)"

if [ ! -f "$JAR_FILE" ]; then
  if [ -z "$WRAPPER_URL" ]; then
    echo "Missing maven-wrapper.jar and wrapperUrl in $PROPS_FILE" >&2
    exit 1
  fi
  echo "Downloading Maven Wrapper jar..." >&2
  mkdir -p "$WRAPPER_DIR"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${MVNW_REPOURL}${WRAPPER_URL}" -o "$JAR_FILE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "${MVNW_REPOURL}${WRAPPER_URL}" -O "$JAR_FILE"
  else
    echo "curl or wget is required to download Maven Wrapper" >&2
    exit 1
  fi
fi

if [ -z "${JAVA_HOME:-}" ]; then
  JAVA_EXEC="java"
else
  JAVA_EXEC="$JAVA_HOME/bin/java"
fi

exec "$JAVA_EXEC" \
  -Dmaven.multiModuleProjectDirectory="$BASE_DIR" \
  -classpath "$JAR_FILE" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"

